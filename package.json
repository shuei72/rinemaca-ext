{
  "name": "rinemaca",
  "displayName": "Rinemaca",
  "description": "Line marker extension for VS Code with session and workspace-persisted markers.",
  "version": "0.0.1",
  "author": "shuei",
  "publisher": "shuei",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "marker",
    "markers",
    "bookmark",
    "line bookmark",
    "line marker",
    "navigation",
    "sidebar"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rinemaca.addSessionLineMarker",
        "title": "Add Session Marker",
        "category": "Rinemaca",
        "shortTitle": "Add Session Marker"
      },
      {
        "command": "rinemaca.addWorkspaceLineMarker",
        "title": "Add Workspace Marker",
        "category": "Rinemaca",
        "shortTitle": "Add Workspace Marker"
      },
      {
        "command": "rinemaca.toggleSessionLineMarker",
        "title": "Toggle Session Marker",
        "category": "Rinemaca",
        "shortTitle": "Toggle Session Marker"
      },
      {
        "command": "rinemaca.toggleWorkspaceLineMarker",
        "title": "Toggle Workspace Marker",
        "category": "Rinemaca",
        "shortTitle": "Toggle Workspace Marker"
      },
      {
        "command": "rinemaca.removeLineMarker",
        "title": "Remove Marker",
        "category": "Rinemaca",
        "shortTitle": "Remove Marker",
        "icon": {
          "light": "media/remove-marker-light.svg",
          "dark": "media/remove-marker-dark.svg"
        }
      },
      {
        "command": "rinemaca.clearSessionMarkers",
        "title": "Clear Session Markers",
        "category": "Rinemaca",
        "shortTitle": "Clear Session Markers"
      },
      {
        "command": "rinemaca.clearWorkspaceMarkers",
        "title": "Clear Workspace Markers",
        "category": "Rinemaca",
        "shortTitle": "Clear Workspace Markers"
      },
      {
        "command": "rinemaca.exportSessionMarkersCsv",
        "title": "Export Session Markers",
        "category": "Rinemaca",
        "shortTitle": "Export Session Markers"
      },
      {
        "command": "rinemaca.exportWorkspaceMarkersCsv",
        "title": "Export Workspace Markers",
        "category": "Rinemaca",
        "shortTitle": "Export Workspace Markers"
      },
      {
        "command": "rinemaca.nextMarker",
        "title": "Next Marker",
        "category": "Rinemaca",
        "shortTitle": "Next Marker"
      },
      {
        "command": "rinemaca.previousMarker",
        "title": "Previous Marker",
        "category": "Rinemaca",
        "shortTitle": "Previous Marker"
      },
      {
        "command": "rinemaca.nextSessionMarker",
        "title": "Next Session Marker",
        "category": "Rinemaca",
        "shortTitle": "Next Session Marker"
      },
      {
        "command": "rinemaca.previousSessionMarker",
        "title": "Previous Session Marker",
        "category": "Rinemaca",
        "shortTitle": "Previous Session Marker"
      },
      {
        "command": "rinemaca.nextWorkspaceMarker",
        "title": "Next Workspace Marker",
        "category": "Rinemaca",
        "shortTitle": "Next Workspace Marker"
      },
      {
        "command": "rinemaca.previousWorkspaceMarker",
        "title": "Previous Workspace Marker",
        "category": "Rinemaca",
        "shortTitle": "Previous Workspace Marker"
      }
    ],
    "submenus": [
      {
        "id": "rinemaca.editorMenu",
        "label": "Rinemaca"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rinemacaSidebar",
          "title": "Rinemaca",
          "icon": "media/rinemaca-panel.svg"
        }
      ]
    },
    "views": {
      "rinemacaSidebar": [
        {
          "id": "rinemacaMarkersView",
          "name": "Markers"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "submenu": "rinemaca.editorMenu",
          "group": "navigation@100"
        }
      ],
      "rinemaca.editorMenu": [
        {
          "command": "rinemaca.toggleSessionLineMarker",
          "group": "1_toggle@1"
        },
        {
          "command": "rinemaca.toggleWorkspaceLineMarker",
          "group": "1_toggle@2"
        }
      ],
      "view/title": [
        {
          "command": "rinemaca.clearSessionMarkers",
          "when": "view == rinemacaMarkersView",
          "group": "clear@1"
        },
        {
          "command": "rinemaca.clearWorkspaceMarkers",
          "when": "view == rinemacaMarkersView",
          "group": "clear@2"
        },
        {
          "command": "rinemaca.exportSessionMarkersCsv",
          "when": "view == rinemacaMarkersView",
          "group": "export@1"
        },
        {
          "command": "rinemaca.exportWorkspaceMarkersCsv",
          "when": "view == rinemacaMarkersView",
          "group": "export@2"
        }
      ],
      "view/item/context": [
        {
          "command": "rinemaca.removeLineMarker",
          "when": "view == rinemacaMarkersView && viewItem == rinemacaSessionMarker",
          "group": "inline"
        },
        {
          "command": "rinemaca.removeLineMarker",
          "when": "view == rinemacaMarkersView && viewItem == rinemacaWorkspaceMarker",
          "group": "inline"
        },
        {
          "command": "rinemaca.removeLineMarker",
          "when": "view == rinemacaMarkersView && viewItem == rinemacaSessionMarker",
          "group": "navigation"
        },
        {
          "command": "rinemaca.removeLineMarker",
          "when": "view == rinemacaMarkersView && viewItem == rinemacaWorkspaceMarker",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Rinemaca",
      "properties": {
        "rinemaca.sessionMarkerBackground": {
          "type": "string",
          "default": "rgba(255, 215, 0, 0.22)",
          "description": "Background color used for session-only line markers."
        },
        "rinemaca.sessionMarkerOverviewRuler": {
          "type": "string",
          "default": "rgba(255, 215, 0, 0.9)",
          "description": "Overview ruler color used for session-only line markers."
        },
        "rinemaca.workspaceMarkerBackground": {
          "type": "string",
          "default": "rgba(64, 156, 255, 0.18)",
          "description": "Background color used for workspace-persisted line markers."
        },
        "rinemaca.workspaceMarkerBorder": {
          "type": "string",
          "default": "rgba(64, 156, 255, 0.85)",
          "description": "Border color used for workspace-persisted line markers."
        },
        "rinemaca.workspaceMarkerOverviewRuler": {
          "type": "string",
          "default": "rgba(64, 156, 255, 0.9)",
          "description": "Overview ruler color used for workspace-persisted line markers."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "1.60.0",
    "typescript": "^5.4.5"
  }
}
